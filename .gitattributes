# Enforce LF line endings for all text files.
# This prevents CRLF noise in diffs on Windows machines.

* text=auto eol=lf

# Source and configuration files — always LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf

# Documentation
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf

# Web assets
*.html      text eol=lf
*.htm       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.svg       text eol=lf

# Shell and config
*.sh        text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
Makefile    text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.avif      binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.zip       binary
*.gz        binary
*.mp4       binary
*.webm      binary
