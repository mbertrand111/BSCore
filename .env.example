# =============================================================================
# BSCore — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
# All variables are consumed via src/socle/config/ — never process.env directly.
# =============================================================================

# Application
NODE_ENV=development
# Public origin — consumed by SEO baseline (metadataBase, sitemap, robots).
# Behavior:
#   - production: REQUIRED. Build/runtime fails fast with a clear error if
#     missing or malformed. Set to the deployed origin (e.g. https://acme.com).
#   - development / test: optional. Falls back to http://localhost:7777.
NEXT_PUBLIC_APP_URL=http://localhost:7777
APP_NAME=BSCore   # Optional — used in /health response; defaults to 'BSCore'

# =============================================================================
# Socle+ — Required only when Socle+ is activated (database + auth projects)
# =============================================================================

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/bscore_dev

# Supabase project credentials
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_KEY=your-service-role-key-here   ← server-side only, never expose to client

# Authentication
# SESSION_SECRET=replace-with-random-string-minimum-32-characters
# JWT_SECRET=replace-with-random-string-minimum-32-characters

# =============================================================================
# Modules — Uncomment when activating the relevant module
# =============================================================================

# Module: Media (file storage)
# STORAGE_BACKEND=supabase   # or: s3
# S3_BUCKET=your-bucket-name
# S3_REGION=eu-west-3
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# Module: Notifications (email)
# EMAIL_PROVIDER=resend   # or: brevo, postmark, smtp
# EMAIL_API_KEY=your-email-api-key
# EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# E2E test credentials — consumed by scripts/seed-e2e-users.ts and Playwright.
# Required to run the auth flow E2E tests. Never commit real values.
# Use throw-away accounts on a dedicated test Supabase project.
# Passwords must satisfy the project's Supabase Auth password policy.
# =============================================================================
# E2E_SUPER_ADMIN_EMAIL=super-admin@e2e.test
# E2E_SUPER_ADMIN_PASSWORD=replace-with-strong-random-password
# E2E_ADMIN_EMAIL=admin@e2e.test
# E2E_ADMIN_PASSWORD=replace-with-strong-random-password
# E2E_USER_EMAIL=no-role@e2e.test          # User with no row in user_roles
# E2E_USER_PASSWORD=replace-with-strong-random-password
